# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# Deepgram (Voice)
DEEPGRAM_API_KEY=...

# Redis (Application Cache)
UPSTASH_REDIS_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_TOKEN=...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SportsIQ

# CV Microservice (Phase 2)
CV_SERVICE_URL=http://cv-service:8000
CV_SERVICE_API_KEY=...
CV_CALLBACK_URL=http://localhost:3000/api/cv/webhook

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_COACH_MONTHLY=price_...
STRIPE_PRICE_COACH_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_ORG_MONTHLY=price_...
STRIPE_PRICE_ORG_ANNUAL=price_...
# First-subscription trial length in days. Set to 0 to disable.
STRIPE_TRIAL_DAYS=14
# Optional — set during webhook secret rotation so both old and new
# signatures verify. Remove once rotation completes (see docs/OPS.md).
# STRIPE_WEBHOOK_SECRET_SECONDARY=whsec_...

# PostHog (Analytics) — leave blank locally; events no-op gracefully without a key.
# Get a project key at https://posthog.com → Project Settings → API Keys.
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Test
E2E_BASE_URL=http://localhost:3000
