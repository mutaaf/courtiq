{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "ignoreCommand": "bash -c 'case \"$VERCEL_GIT_COMMIT_REF\" in main|swarm/*|fix/*|feat/*|improve/*|docs/*|chore/*) exit 1 ;; esac; [ -n \"$VERCEL_GIT_PULL_REQUEST_ID\" ] && exit 1; exit 0'",
  "crons": [
    {
      "path": "/api/cron/drip-emails",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/practice-reminder",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/weekly-parent-rollup",
      "schedule": "5 8 * * 1"
    },
    {
      "path": "/api/cron/parent-digest",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/cron/refresh-drill-sequences",
      "schedule": "0 3 * * *"
    }
  ]
}
